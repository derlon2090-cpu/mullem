{
  "name": "mullem-root-app",
  "private": true,
  "version": "1.0.0",
  "description": "Mullem static frontend with root Node API server",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node render-ensure-runtime.js && node server.js",
    "dev": "node server.js",
    "test:backend": "node backend-smoke-test.js",
    "ai:seed": "node ai-knowledge-seed.js",
    "ai:smoke": "node ai-smoke-test.js",
    "ai:quality": "node ai-quality-validation.js",
    "ai:load-test": "node ai-load-test.js",
    "security:audit": "node security-audit-check.js",
    "ai:release-gate": "npm run ai:smoke && npm run ai:quality && npm run ai:real-scale-check && npm run ai:load-test && npm run ai:production-activation-check",
    "ai:launch-check": "node ai-launch-readiness.js",
    "ai:beta-report": "node ai-beta-weekly-report.js",
    "ai:scale-check": "node ai-scale-growth-check.js",
    "ai:real-scale-check": "node ai-real-scale-check.js",
    "ai:production-activation-check": "node ai-production-activation-check.js",
    "ai:alpha-check": "node ai-alpha-check.js",
    "ai:worker": "node ai-worker.js",
    "ai:service": "node ai-service.js",
    "render:build": "npm ci && node render-build-check.js",
    "render:start": "node render-ensure-runtime.js && node server.js"
  },
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3"
  }
}
