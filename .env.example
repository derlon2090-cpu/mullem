APP_NAME=Mullem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Accepted alternatives when using Vercel/Neon integrations:
# POSTGRES_URL=postgresql://user:password@host/database?sslmode=require
# POSTGRES_PRISMA_URL=postgresql://user:password@host/database?sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database?sslmode=require
# NEON_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DOMAIN=localhost

MULLEM_FRONTEND_URL=http://localhost

# Auth/OAuth configuration. Leave provider keys empty to show a clear
# "خدمة تسجيل الدخول غير مفعلة حاليًا" message instead of a generic login error.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=

OPENAI_API_KEY=
ORLIXOR_DEFAULT_PROVIDER=openai
ORLIXOR_DEFAULT_MODEL=gpt-4.1-mini
ORLIXOR_TURBO_PROVIDER=openai
ORLIXOR_TURBO_MODEL=gpt-4.1-mini
ORLIXOR_PRO_PROVIDER=openai
ORLIXOR_PRO_MODEL=gpt-4.1-mini
ORLIXOR_CREATIVE_PROVIDER=openai
ORLIXOR_CREATIVE_MODEL=gpt-4.1-mini
ORLIXOR_ALPHA_PROVIDER=openai
ORLIXOR_ALPHA_MODEL=gpt-4.1-mini
ORLIXOR_ALPHA_ACCESS=admin,beta_tester,pioneer
OPENAI_MODEL=gpt-4.1-mini
ORLIXOR_VISION_MODEL=gpt-4.1-mini
ORLIXOR_IMAGE_ANALYSIS_PROVIDER=openai
ORLIXOR_IMAGE_ANALYSIS_MODEL=gpt-4.1-mini
ORLIXOR_IMAGE_GENERATION_PROVIDER=openai
ORLIXOR_IMAGE_GENERATION_MODEL=gpt-image-1-mini
ORLIXOR_IMAGE_GENERATION_PRO_MODEL=gpt-image-1.5
OPENAI_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses
OPENAI_CHAT_COMPLETIONS_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_IMAGES_GENERATIONS_ENDPOINT=https://api.openai.com/v1/images/generations
OPENAI_IMAGES_EDITS_ENDPOINT=https://api.openai.com/v1/images/edits
OPENAI_EMBEDDINGS_ENDPOINT=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ORLIXOR_ENABLE_EMBEDDINGS=false
OPENAI_TIMEOUT_MS=25000
OPENAI_MAX_OUTPUT_TOKENS=1600
DB_INIT_TIMEOUT_MS=8000
DB_CONNECT_TIMEOUT_MS=8000
CORS_ALLOWED_ORIGINS=*
MAX_BODY_BYTES=8000000
MAX_IMAGE_INPUTS=4
MAX_IMAGE_DATA_URL_BYTES=1800000
IMAGE_TOOL_MAX_FILE_SIZE=10485760
IMAGE_PROMPT_MAX_LENGTH=32000
MAX_MESSAGE_LENGTH=4000
MAX_QUESTION_LENGTH=4000
MAX_METADATA_LENGTH=120
MAX_HISTORY_MESSAGES=5
TEXT_MESSAGE_XP_COST=10
IMAGE_GENERATION_XP_COST=15
ATTACHMENT_ANALYSIS_XP_COST=20
IMAGE_ANALYZE_XP_COST=5
IMAGE_GENERATE_STANDARD_XP_COST=20
IMAGE_GENERATE_HIGH_XP_COST=35
IMAGE_EDIT_XP_COST=25
DAILY_LOGIN_XP_REWARD=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_SOLVE_MAX=20
RATE_LIMIT_GENERAL_MAX=60
MULLEM_AI_PROVIDER=openai
MULLEM_AI_TEMPERATURE=0.2
MULLEM_AI_TIMEOUT=20
MULLEM_AI_STREAM=true
MULLEM_AI_PROMPT_KEY=student-chat

MULLEM_PAYMENT_GATEWAY=myfatoorah
